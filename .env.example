# Copy to .env and fill in. Never commit .env.

# --- Database & AI ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
GROQ_API_KEY=

# Simulation tick (ms). Default 30000. Set ≥ (num_agents × GROQ_MIN_DELAY_MS) to finish each tick before the next.
# TICK_INTERVAL_MS=30000
# Groq: sequential delay between agent calls (ms). ~2100 keeps free-tier RPM safer. Set 0 if your plan allows bursts.
# GROQ_MIN_DELAY_MS=2100
# Groq parallel calls per tick (default 1). Raise only with higher rate limits.
# GROQ_MAX_CONCURRENT=1
# Retries on 429 rate limit
# GROQ_MAX_RETRIES=3
# Food: consume 1 unit every N ticks (default 2). Use 1 for old harsh “every tick” behavior.
# FOOD_CONSUME_EVERY_N_TICKS=2

# --- Server ---
PORT=3000

# Admin: min 12 chars. Protects simulation start/stop, POST /markets, POST /markets/trade
ADMIN_API_KEY=

# --- Base / prediction market (required for wallet trading in the UI) ---
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Must be ChaosParimutuelMarket (parimutuel). If register:market says "CPMM", you pointed at the old contract or deployed with a broken script — run compile + deploy again and paste the new address here.
# npm run compile:contracts && npm run deploy:contract
PREDICTION_MARKET_CONTRACT_ADDRESS=

PROTOCOL_TREASURY_ADDRESS=
PROTOCOL_FEE_BPS=200

# Optional: ISO 8601 datetime used by `npm run seed` for the default market `betting_closes_at`
# MARKET_CLOSES_AT=

# Optional: identical starting stats for every agent (seed / db:reset)
# SEED_START_CREDITS=100
# SEED_START_FOOD=20
# SEED_START_ENERGY=10

# Optional dev only
ALLOW_UNVERIFIED_TRADES=false

# Deploy script (scripts/deploy.cjs) — keep secret
# Use one of these names (64 hex chars, with or without 0x):
DEPLOYER_PRIVATE_KEY=
# PRIVATE_KEY=
# ETH_PRIVATE_KEY=
