# Copy to .env and fill in. Never commit .env.

# --- Database & AI ---
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
GROQ_API_KEY=

# --- Server ---
PORT=3000

# Admin: min 12 chars. Protects simulation start/stop, POST /markets, POST /markets/trade
ADMIN_API_KEY=

# --- Base / prediction market (required for wallet trading in the UI) ---
BASE_RPC_URL=https://mainnet.base.org
BASE_CHAIN_ID=8453
USDC_CONTRACT_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# Must be ChaosParimutuelMarket (parimutuel). If register:market says "CPMM", you pointed at the old contract or deployed with a broken script — run compile + deploy again and paste the new address here.
# npm run compile:contracts && npm run deploy:contract
PREDICTION_MARKET_CONTRACT_ADDRESS=

PROTOCOL_TREASURY_ADDRESS=
PROTOCOL_FEE_BPS=200

# Optional dev only
ALLOW_UNVERIFIED_TRADES=false

# Deploy script (scripts/deploy.cjs) — keep secret
# Use one of these names (64 hex chars, with or without 0x):
DEPLOYER_PRIVATE_KEY=
# PRIVATE_KEY=
# ETH_PRIVATE_KEY=
